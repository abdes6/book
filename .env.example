# Flask 密钥 — 用于 session 签名，可使用随机字符串
# 不设置时系统会自动生成随机密钥
# SECRET_KEY=your-secret-key-here

# 数据库连接（默认使用 SQLite，设置此变量可切换 MySQL）
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/book_collection

# DeepSeek AI API 密钥（不设置则 AI 功能不可用，其他功能正常）
# 注册获取：https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
